    {
      "id": "distinct-order-limit",
      "title": "DISTINCT, AS, ORDER BY, LIMIT та OFFSET",
      "sections": [
        {
          "id": "distinct",
          "title": "DISTINCT — унікальні значення",
          "content": [
            {
              "type": "syntax",
              "code": "SELECT DISTINCT колонка FROM таблиця;"
            },
            {
              "type": "card",
              "title": "Одна колонка",
              "description": "Повертає тільки унікальні міста — без повторів.",
              "code": "SELECT DISTINCT city FROM users;",
              "visualization": true
            },
            {
              "type": "card",
              "title": "Кілька колонок",
              "description": "DISTINCT розглядає комбінацію всіх обраних колонок — унікальними мають бути пари.",
              "code": "SELECT DISTINCT city, status FROM users;"
            },
            {
              "type": "warning",
              "text": "DISTINCT завжди стоїть одразу після SELECT, до списку колонок. Не можна написати SELECT name, DISTINCT city."
            }
          ]
        },
        {
          "id": "as",
          "title": "AS — псевдоніми колонок і таблиць",
          "content": [
            {
              "type": "syntax",
              "code": "SELECT вираз AS псевдонім FROM таблиця AS псевдонім;"
            },
            {
              "type": "two-column",
              "items": [
                {
                  "title": "Псевдонім колонки",
                  "description": "Змінює назву у результаті — зручно для читабельності.",
                  "code": "SELECT\n  name  AS full_name,\n  age   AS years\nFROM users;"
                },
                {
                  "title": "Псевдонім таблиці",
                  "description": "Скорочує назву таблиці — особливо корисно при JOIN.",
                  "code": "SELECT u.name, u.city\nFROM users AS u\nWHERE u.age > 18;"
                }
              ]
            },
            {
              "type": "card",
              "title": "Псевдонім для виразу або функції",
              "description": "Будь-який обчислений вираз можна назвати зрозуміло.",
              "code": "SELECT\n  name,\n  price * 1.2        AS price_with_vat,\n  UPPER(name)        AS name_upper,\n  COUNT(*)           AS total_users\nFROM products;"
            },
            {
              "type": "tip",
              "text": "Слово AS можна опустити — name full_name теж працює. Але з AS читабельніше."
            }
          ]
        },
        {
          "id": "order-by",
          "title": "ORDER BY — сортування результату",
          "content": [
            {
              "type": "syntax",
              "code": "SELECT ... FROM ... ORDER BY колонка [ASC | DESC];"
            },
            {
              "type": "two-column",
              "items": [
                {
                  "title": "ASC — за зростанням",
                  "description": "За замовчуванням — можна не писати.",
                  "code": "SELECT * FROM users\nORDER BY age ASC;"
                },
                {
                  "title": "DESC — за спаданням",
                  "description": "Від найбільшого до найменшого.",
                  "code": "SELECT * FROM users\nORDER BY age DESC;"
                }
              ]
            },
            {
              "type": "card",
              "title": "Сортування за кількома колонками",
              "description": "Спочатку сортує за першою колонкою, при однакових значеннях — за другою.",
              "code": "SELECT name, city, age FROM users\nORDER BY city ASC, age DESC;"
            },
            {
              "type": "card",
              "title": "Сортування за псевдонімом або номером",
              "description": "Можна посилатись на AS-псевдонім або порядковий номер колонки у SELECT.",
              "code": "SELECT name, age * 2 AS double_age\nFROM users\nORDER BY double_age DESC;\n\n-- або за номером: ORDER BY 2 DESC"
            }
          ]
        },
        {
          "id": "limit-offset",
          "title": "LIMIT та OFFSET — обмеження кількості рядків",
          "content": [
            {
              "type": "syntax",
              "code": "SELECT ... FROM ... ORDER BY ... LIMIT n OFFSET m;"
            },
            {
              "type": "two-column",
              "items": [
                {
                  "title": "LIMIT — перші N рядків",
                  "code": "SELECT * FROM users\nORDER BY age DESC\nLIMIT 5;\n-- 5 найстарших"
                },
                {
                  "title": "OFFSET — пропустити M рядків",
                  "code": "SELECT * FROM users\nORDER BY age DESC\nLIMIT 5 OFFSET 10;\n-- рядки 11–15"
                }
              ]
            },
            {
              "type": "card",
              "title": "Пагінація — посторінкове виведення",
              "description": "Типовий патерн для сторінок: OFFSET = (сторінка − 1) × розмір",
              "code": "-- Сторінка 1 (рядки 1–10)\nSELECT * FROM products ORDER BY id LIMIT 10 OFFSET 0;\n\n-- Сторінка 2 (рядки 11–20)\nSELECT * FROM products ORDER BY id LIMIT 10 OFFSET 10;\n\n-- Сторінка 3 (рядки 21–30)\nSELECT * FROM products ORDER BY id LIMIT 10 OFFSET 20;"
            },
            {
              "type": "warning",
              "text": "LIMIT без ORDER BY повертає рядки у довільному порядку — результат може бути різним при кожному виконанні. Завжди додавай сортування."
            }
          ]
        },
        {
          "id": "full-example",
          "title": "Все разом — повний приклад",
          "content": [
            {
              "type": "card",
              "description": "Топ-5 унікальних міст з найбільшою кількістю активних користувачів старших 18 років, починаючи з 6-го результату.",
              "code": "SELECT DISTINCT\n  city                  AS user_city,\n  COUNT(*)              AS total\nFROM  users             AS u\nWHERE u.age > 18\n  AND  u.status = 'active'\nORDER BY total DESC\nLIMIT  5\nOFFSET 5;"
            }
          ]
        },
